# .env.example — copy to .env and fill in values; NEVER commit .env

# Yahoo Fantasy API
# Path to the oauth2.json credentials file generated by auth/setup_yahoo.py
YAHOO_OAUTH_CREDS_FILE=oauth2.json
YAHOO_LEAGUE_ID=449.l.12345

# ESPN Fantasy API (cookie-based, alternative to Yahoo)
# Extract these from browser devtools → Application → Cookies → yahoo.com
ESPN_S2=AEBxxxxxxxxxxxxxxxxxxxxxx
ESPN_SWID={XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}
ESPN_LEAGUE_ID=12345678
ESPN_SEASON_YEAR=2025

# Optional
LOG_LEVEL=INFO
