# .env.example — copy to .env and fill in values; NEVER commit .env

# Yahoo Fantasy API
# Path to the oauth2.json credentials file generated by auth/web_server.py
YAHOO_OAUTH_CREDS_FILE=oauth2.json
YAHOO_LEAGUE_ID=449.l.12345
YAHOO_CLIENT_ID=dj0yJmk9eXZMM01hVEhtRUVPJmQ9WVdrOVpXMWtRWGhTTUVZbWNHbzlNQT09JnM9Y29uc3VtZXJzZWNyZXQmc3Y9MCZ4PWUw
YAHOO_CLIENT_SECRET=

# ESPN Fantasy API (cookie-based, alternative to Yahoo)
# Extract these from browser devtools → Application → Cookies → yahoo.com
ESPN_S2=AEBxxxxxxxxxxxxxxxxxxxxxx
ESPN_SWID={XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}
ESPN_LEAGUE_ID=12345678
ESPN_SEASON_YEAR=2025

# Optional
LOG_LEVEL=INFO
# Public base URL — set this when hosting for others so auth links are correct.
# Defaults to https://localhost:8000 for local development.
# BASE_URL=https://hockeybot.example.com
AUTH_SERVER_PORT=8000
SESSION_SECRET=change-me-to-a-random-string

# SSL — point requests/ssl at the system CA bundle so the self-signed localhost
# cert (installed via postCreateCommand) is trusted by Python HTTP clients.
# certifi ships its own bundle and ignores update-ca-certificates without these.
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
